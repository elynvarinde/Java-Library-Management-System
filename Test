    static void addSeedBook(String title, String author, String isbn,
                             String genre, int year, int copies) {
        Book b = new Book(title, author, isbn, genre, year, copies);
        books.put(b.id, b);
    }

    static void addSeedMember(String name, String email, String phone) {
        Member m = new Member(name, email, phone);
        members.put(m.id, m);
    }

    static void createSeedLoan(int memberId, int bookId) {
        Member member = members.get(memberId);
        Book book     = books.get(bookId);
        if (member == null || book == null || !book.isAvailable()) return;
        Loan loan = new Loan(memberId, bookId);
        loans.put(loan.id, loan);
        member.borrowedLoanIds.add(loan.id);
        book.availableCopies--;
    }

