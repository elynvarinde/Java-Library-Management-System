import java.util.*;
import java.time.*;
import java.time.format.DateTimeFormatter;
import java.time.temporal.ChronoUnit;

/**
 * ============================================================
 *          JAVA LIBRARY MANAGEMENT SYSTEM
 *          A fully-featured console application
 * ============================================================
 *
 *  Features:
 *   - Add, remove, search, and list books
 *   - Register and manage members
 *   - Borrow and return books with due dates
 *   - Fine calculation for overdue books
 *   - Statistics and reports
 *   - Persistent in-memory state with sample data
 *
 *  Run: javac LibraryManagementSystem.java && java LibraryManagementSystem
 * ============================================================
 */
public class LibraryManagementSystem {

    // ─── CONSTANTS ────────────────────────────────────────────────────────────
    static final int LOAN_DAYS         = 14;
    static final double FINE_PER_DAY   = 0.50;
    static final int MAX_BOOKS_PER_MEMBER = 5;
    static final DateTimeFormatter DATE_FMT =
        DateTimeFormatter.ofPattern("yyyy-MM-dd");

    // ─── BOOK ─────────────────────────────────────────────────────────────────
    static class Book {
        private static int idCounter = 1000;

        final int    id;
        String       title;
        String       author;
        String       isbn;
        String       genre;
        int          year;
        int          totalCopies;
        int          availableCopies;

        Book(String title, String author, String isbn,
             String genre, int year, int copies) {
            this.id              = idCounter++;
            this.title           = title;
            this.author          = author;
            this.isbn            = isbn;
            this.genre           = genre;
            this.year            = year;
            this.totalCopies     = copies;
            this.availableCopies = copies;
        }

        boolean isAvailable() { return availableCopies > 0; }

        @Override
        public String toString() {
            return String.format(
                "[%d] %-35s | %-22s | %-15s | %d | %d/%d copies",
                id, truncate(title, 34), truncate(author, 21),
                genre, year, availableCopies, totalCopies
            );
        }
    }

    // ─── MEMBER ───────────────────────────────────────────────────────────────
    static class Member {
        private static int idCounter = 2000;

        final int    id;
        String       name;
        String       email;
        String       phone;
        LocalDate    joinDate;
        boolean      active;
        List<Integer> borrowedLoanIds;

        Member(String name, String email, String phone) {
            this.id             = idCounter++;
            this.name           = name;
            this.email          = email;
            this.phone          = phone;
            this.joinDate       = LocalDate.now();
            this.active         = true;
            this.borrowedLoanIds = new ArrayList<>();
        }

        int borrowCount() { return borrowedLoanIds.size(); }

        @Override
        public String toString() {
            return String.format(
                "[%d] %-25s | %-28s | %-14s | Books: %d | %s",
                id, truncate(name, 24), truncate(email, 27),
                phone, borrowCount(), active ? "Active" : "Inactive"
            );
        }
    }

    // ─── LOAN ─────────────────────────────────────────────────────────────────
    static class Loan {
        private static int idCounter = 3000;

        final int        id;
        final int        memberId;
        final int        bookId;
        final LocalDate  borrowDate;
        LocalDate        dueDate;
        LocalDate        returnDate;
        boolean          returned;
        double           fine;

        Loan(int memberId, int bookId) {
            this.id         = idCounter++;
            this.memberId   = memberId;
            this.bookId     = bookId;
            this.borrowDate = LocalDate.now();
            this.dueDate    = borrowDate.plusDays(LOAN_DAYS);
            this.returned   = false;
            this.fine       = 0.0;
        }

        boolean isOverdue() {
            return !returned && LocalDate.now().isAfter(dueDate);
        }

        long daysOverdue() {
            if (!isOverdue()) return 0;
            return ChronoUnit.DAYS.between(dueDate, LocalDate.now());
        }

        double calculateFine() {
            return daysOverdue() * FINE_PER_DAY;
        }

        @Override
        public String toString() {
            String status = returned
                ? "Returned " + returnDate.format(DATE_FMT)
                : (isOverdue() ? "OVERDUE (" + daysOverdue() + " days)" : "Active");
            return String.format(
                "[%d] Member:%d  Book:%d  Borrowed:%s  Due:%s  Status:%s  Fine:$%.2f",
                id, memberId, bookId,
                borrowDate.format(DATE_FMT),
                dueDate.format(DATE_FMT),
                status,
                returned ? fine : calculateFine()
            );
        }
    }

    // ─── DATA STORE ───────────────────────────────────────────────────────────
    static Map<Integer, Book>   books   = new LinkedHashMap<>();
    static Map<Integer, Member> members = new LinkedHashMap<>();
    static Map<Integer, Loan>   loans   = new LinkedHashMap<>();
    static Scanner sc = new Scanner(System.in);

