        System.out.println("╚═══════════════════════════════════════════╝");
        System.out.printf("  Loaded: %d books | %d members | %d loans%n",
            books.size(), members.size(), loans.size());
    }

    static void printSectionHeader(String title) {
        System.out.println("\n┌─ " + title + " " + "─".repeat(Math.max(0, 44 - title.length())) + "┐");
    }

    static void printBookHeader() {
        System.out.println(" ID    Title                                Author                 Genre           Year  Copies");
        System.out.println(" ──────────────────────────────────────────────────────────────────────────────────────────────");
    }

    static void ok(String msg)   { System.out.println("  ✔ " + msg); }
    static void info(String msg) { System.out.println("  ℹ " + msg); }
    static void warn(String msg) { System.out.println("  ✘ " + msg); }

    static String truncate(String s, int max) {
        return s.length() <= max ? s : s.substring(0, max - 1) + "…";
    }

    static int readInt(String prompt) {
        while (true) {
            System.out.print(prompt);
            try {
                return Integer.parseInt(sc.nextLine().trim());
            } catch (NumberFormatException e) {
                warn("Please enter a valid number.");
            }
        }
    }

    static String readString(String prompt) {
        System.out.print(prompt);
        return sc.nextLine().trim();
    }

    static String readStringOptional(String prompt) {
        System.out.print(prompt);
        return sc.nextLine().trim();
    }
}
	
