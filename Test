    static void listMembers() {
        printSectionHeader("ALL MEMBERS (" + members.size() + ")");
        if (members.isEmpty()) { info("No members registered."); return; }
        members.values().forEach(System.out::println);
    }

    static void searchMembers() {
        String query = readString("Search (name/email/phone): ").toLowerCase();
        List<Member> results = members.values().stream()
            .filter(m -> m.name.toLowerCase().contains(query)
                      || m.email.toLowerCase().contains(query)
                      || m.phone.contains(query))
            .toList();
        printSectionHeader("SEARCH RESULTS (" + results.size() + ")");
        if (results.isEmpty()) { info("No members found."); return; }
        results.forEach(System.out::println);
    }

    static void addMember() {
        printSectionHeader("REGISTER NEW MEMBER");
        String name  = readString("Full name: ");
        String email = readString("Email: ");
        String phone = readString("Phone: ");
        Member member = new Member(name, email, phone);
        members.put(member.id, member);
        ok("Member registered! ID: " + member.id);
    }

    static void editMember() {
        int id = readInt("Enter Member ID to edit: ");
        Member m = members.get(id);
        if (m == null) { warn("Member not found."); return; }
        System.out.println("Current: " + m);
        String name  = readStringOptional("New name [" + m.name + "]: ");
        String email = readStringOptional("New email [" + m.email + "]: ");
        String phone = readStringOptional("New phone [" + m.phone + "]: ");
        if (!name.isEmpty())  m.name  = name;
        if (!email.isEmpty()) m.email = email;
        if (!phone.isEmpty()) m.phone = phone;
        ok("Member updated.");
    }

    static void deactivateMember() {
        int id = readInt("Enter Member ID to deactivate: ");
        Member m = members.get(id);
        if (m == null) { warn("Member not found."); return; }
        if (!m.active) { warn("Member is already inactive."); return; }
        if (!m.borrowedLoanIds.isEmpty()) {
            warn("Member has active loans. Return all books first.");
            return;
        }
        m.active = false;
        ok("Member deactivated.");
    }

    // ─── LOAN OPERATIONS ─────────────────────────────────────────────────────
    static void borrowBook() {
        printSectionHeader("BORROW A BOOK");
        int memberId = readInt("Member ID: ");
        Member member = members.get(memberId);
        if (member == null)  { warn("Member not found."); return; }
        if (!member.active)  { warn("Member account is inactive."); return; }
        if (member.borrowCount() >= MAX_BOOKS_PER_MEMBER) {
            warn("Member has reached the borrow limit of " + MAX_BOOKS_PER_MEMBER + " books.");
            return;
        }

        int bookId = readInt("Book ID: ");
        Book book = books.get(bookId);
        if (book == null)         { warn("Book not found."); return; }
        if (!book.isAvailable())  { warn("No available copies of this book."); return; }

        boolean alreadyBorrowed = loans.values().stream()
            .anyMatch(l -> l.memberId == memberId && l.bookId == bookId && !l.returned);
        if (alreadyBorrowed) {
            warn("This member already has this book borrowed.");
            return;
        }

        Loan loan = new Loan(memberId, bookId);
        loans.put(loan.id, loan);
        member.borrowedLoanIds.add(loan.id);
        book.availableCopies--;

        ok("Book borrowed successfully!");
        System.out.printf("  Loan ID  : %d%n", loan.id);
        System.out.printf("  Book     : %s%n", book.title);
        System.out.printf("  Member   : %s%n", member.name);
        System.out.printf("  Due Date : %s%n", loan.dueDate.format(DATE_FMT));
    }

    static void returnBook() {
        printSectionHeader("RETURN A BOOK");
        int loanId = readInt("Loan ID: ");
        Loan loan = loans.get(loanId);
        if (loan == null)     { warn("Loan not found."); return; }
        if (loan.returned)    { warn("This loan has already been returned."); return; }

        loan.returnDate = LocalDate.now();
        loan.returned   = true;
        loan.fine       = loan.calculateFine();

        Book book = books.get(loan.bookId);
        book.availableCopies++;

        Member member = members.get(loan.memberId);
        member.borrowedLoanIds.remove(Integer.valueOf(loan.id));

        ok("Book returned successfully!");
        if (loan.fine > 0) {
            System.out.printf("  ⚠ Overdue fine: $%.2f (%.0f days late)%n",
                loan.fine, (double) ChronoUnit.DAYS.between(loan.dueDate, loan.returnDate));
        } else {
            System.out.println("  No fine — returned on time.");
        }
    }

    static void listActiveLoans() {
        printSectionHeader("ACTIVE LOANS");
        List<Loan> active = loans.values().stream()
            .filter(l -> !l.returned).toList();
        if (active.isEmpty()) { info("No active loans."); return; }
        active.forEach(l -> {
            Book b   = books.get(l.bookId);
            Member m = members.get(l.memberId);
            System.out.printf("%s%n  → \"%s\" borrowed by %s%n",
                l, b != null ? b.title : "?", m != null ? m.name : "?");
        });
    }

    static void listOverdueLoans() {
        printSectionHeader("OVERDUE LOANS");
        List<Loan> overdue = loans.values().stream()
            .filter(Loan::isOverdue).toList();
        if (overdue.isEmpty()) { ok("No overdue loans!"); return; }
        overdue.forEach(l -> {
            Book b   = books.get(l.bookId);
            Member m = members.get(l.memberId);
            System.out.printf("%s%n  → \"%s\" borrowed by %s | Fine: $%.2f%n",
                l, b != null ? b.title : "?",
                m != null ? m.name : "?", l.calculateFine());
        });
    }

    static void viewMemberLoans() {
        int memberId = readInt("Member ID: ");
        Member member = members.get(memberId);
        if (member == null) { warn("Member not found."); return; }
        printSectionHeader("LOANS FOR: " + member.name);
        List<Loan> memberLoans = loans.values().stream()
            .filter(l -> l.memberId == memberId).toList();
        if (memberLoans.isEmpty()) { info("No loan history."); return; }
        memberLoans.forEach(l -> {
            Book b = books.get(l.bookId);
            System.out.printf("%s%n  → \"%s\"%n", l, b != null ? b.title : "?");
        });
    }

    // ─── REPORTS ─────────────────────────────────────────────────────────────
    static void summarizeLibrary() {
        printSectionHeader("LIBRARY SUMMARY");
        int totalBooks      = books.values().stream().mapToInt(b -> b.totalCopies).sum();
        int availableBooks  = books.values().stream().mapToInt(b -> b.availableCopies).sum();
        int borrowedBooks   = totalBooks - availableBooks;
        long activeMembers  = members.values().stream().filter(m -> m.active).count();
        long activeLoans    = loans.values().stream().filter(l -> !l.returned).count();
        long overdueLoans   = loans.values().stream().filter(Loan::isOverdue).count();
        double totalFines   = loans.values().stream().mapToDouble(Loan::calculateFine).sum();

        System.out.printf("  Unique titles    : %d%n", books.size());
        System.out.printf("  Total copies     : %d%n", totalBooks);
        System.out.printf("  Available copies : %d%n", availableBooks);
        System.out.printf("  Currently on loan: %d%n", borrowedBooks);
        System.out.printf("  Total members    : %d (Active: %d)%n",
            members.size(), activeMembers);
        System.out.printf("  Active loans     : %d%n", activeLoans);
        System.out.printf("  Overdue loans    : %d%n", overdueLoans);
        System.out.printf("  Outstanding fines: $%.2f%n", totalFines);
    }

    static void mostBorrowedBooks() {
        printSectionHeader("MOST BORROWED BOOKS (Top 10)");
        Map<Integer, Long> counts = new HashMap<>();
        loans.values().forEach(l -> counts.merge(l.bookId, 1L, Long::sum));
        counts.entrySet().stream()
            .sorted(Map.Entry.<Integer, Long>comparingByValue().reversed())
            .limit(10)
            .forEach(e -> {
                Book b = books.get(e.getKey());
                System.out.printf("  %3dx  [%d] %s — %s%n",
                    e.getValue(), e.getKey(),
                    b != null ? b.title : "Unknown",
                    b != null ? b.author : "");
            });
    }

    static void mostActiveMembers() {
        printSectionHeader("MOST ACTIVE MEMBERS (Top 10)");
        Map<Integer, Long> counts = new HashMap<>();
        loans.values().forEach(l -> counts.merge(l.memberId, 1L, Long::sum));
        counts.entrySet().stream()
            .sorted(Map.Entry.<Integer, Long>comparingByValue().reversed())
            .limit(10)
            .forEach(e -> {
                Member m = members.get(e.getKey());
                System.out.printf("  %3d loans  [%d] %s%n",
                    e.getValue(), e.getKey(),
                    m != null ? m.name : "Unknown");
            });
    }

    static void finesSummary() {
        printSectionHeader("FINES SUMMARY");
        double total   = loans.values().stream().mapToDouble(l ->
            l.returned ? l.fine : l.calculateFine()).sum();
        double collected = loans.values().stream().filter(l -> l.returned)
            .mapToDouble(l -> l.fine).sum();
        double outstanding = loans.values().stream().filter(l -> !l.returned)
            .mapToDouble(Loan::calculateFine).sum();
        System.out.printf("  Total fines      : $%.2f%n", total);
        System.out.printf("  Collected        : $%.2f%n", collected);
        System.out.printf("  Outstanding      : $%.2f%n", outstanding);
        System.out.printf("  Rate per day     : $%.2f%n", FINE_PER_DAY);
    }

    static void genreBreakdown() {
        printSectionHeader("BOOKS BY GENRE");
        Map<String, Long> genreCount = new LinkedHashMap<>();
        books.values().forEach(b -> genreCount.merge(b.genre, 1L, Long::sum));
        genreCount.entrySet().stream()
            .sorted(Map.Entry.<String, Long>comparingByValue().reversed())
            .forEach(e -> System.out.printf("  %-20s %d title(s)%n",
                e.getKey(), e.getValue()));
    }

