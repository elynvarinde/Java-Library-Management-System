    // ─── BOOK OPERATIONS ─────────────────────────────────────────────────────
    static void listBooks() {
        printSectionHeader("ALL BOOKS (" + books.size() + ")");
        if (books.isEmpty()) { info("No books in the library."); return; }
        printBookHeader();
        books.values().forEach(System.out::println);
    }

    static void searchBooks() {
        String query = readString("Search (title/author/isbn/genre): ").toLowerCase();
        List<Book> results = books.values().stream()
            .filter(b -> b.title.toLowerCase().contains(query)
                      || b.author.toLowerCase().contains(query)
                      || b.isbn.toLowerCase().contains(query)
                      || b.genre.toLowerCase().contains(query))
            .toList();
        printSectionHeader("SEARCH RESULTS (" + results.size() + ")");
        if (results.isEmpty()) { info("No books found."); return; }
        printBookHeader();
        results.forEach(System.out::println);
    }

    static void addBook() {
        printSectionHeader("ADD NEW BOOK");
        String title  = readString("Title: ");
        String author = readString("Author: ");
        String isbn   = readString("ISBN: ");
        String genre  = readString("Genre: ");
        int year      = readInt("Year: ");
        int copies    = readInt("Number of copies: ");
        if (copies < 1) { warn("Copies must be at least 1."); return; }
        Book book = new Book(title, author, isbn, genre, year, copies);
        books.put(book.id, book);
        ok("Book added successfully! ID: " + book.id);
    }

    static void editBook() {
        int id = readInt("Enter Book ID to edit: ");
        Book book = books.get(id);
        if (book == null) { warn("Book not found."); return; }
        System.out.println("Current: " + book);
        System.out.println("(Press Enter to keep current value)");
        String title  = readStringOptional("New title [" + book.title + "]: ");
        String author = readStringOptional("New author [" + book.author + "]: ");
        String genre  = readStringOptional("New genre [" + book.genre + "]: ");
        if (!title.isEmpty())  book.title  = title;
        if (!author.isEmpty()) book.author = author;
        if (!genre.isEmpty())  book.genre  = genre;
        ok("Book updated.");
    }

    static void removeBook() {
        int id = readInt("Enter Book ID to remove: ");
        Book book = books.get(id);
        if (book == null) { warn("Book not found."); return; }
        boolean hasActiveLoans = loans.values().stream()
            .anyMatch(l -> l.bookId == id && !l.returned);
        if (hasActiveLoans) {
            warn("Cannot remove book — it has active loans.");
            return;
        }
        System.out.print("Confirm removal of '" + book.title + "'? (y/n): ");
        if (sc.nextLine().trim().equalsIgnoreCase("y")) {
            books.remove(id);
            ok("Book removed.");
        } else {
            info("Removal cancelled.");
        }
    }

